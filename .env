OUTCOMES_WARMUP_TOPN=30

# Favorites storage directory (server-side per-user favorites)
FAVORITES_DIR=/app/favorites

# Request price suggestion (market.csgo order book + sales history)
# Target % of sales median (3% below median = fair for seller, discount for buyer)
MC_REQUEST_MEDIAN_RATIO=0.97
# Hard ceiling: suggested price never exceeds ask * this (always cheaper than ask)
MC_REQUEST_MAX_VS_ASK=0.95
# Hard floor: don't lowball below ask * this (seller won't accept)
MC_REQUEST_MIN_VS_ASK=0.70
# Fallback ratio of ask when no sales history available
MC_REQUEST_FALLBACK_RATIO=0.90
# Min number of sales needed to use median (otherwise use fallback)
MC_REQUEST_MIN_SALES=5
# Instant-sell: only show if bid >= this fraction of ask (filters stale/junk bids)
MC_SELL_MIN_BID_VS_ASK=0.70
# BID mode: include bids >= this fraction of ask as valid buy targets (lower threshold)
BID_MODE_MIN_BID_VS_ASK=0.30
# BID mode: max DMarket titles to query for bid prices per refresh
BID_DM_MAX_TITLES=300


PRICE_SOURCE_MODE=v1_first
