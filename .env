# ── Mini App (Telegram Web App) ──────────────────────────────────────────────
# Local server port (used by webapp_server.py)
WEBAPP_PORT=7860
WEBAPP_HOST=0.0.0.0
# Public HTTPS URL where the Mini App is served (required for Telegram).
# Use ngrok or any reverse proxy tunnel to expose WEBAPP_PORT externally.
# Example: WEBAPP_URL=https://abc123.ngrok.io
WEBAPP_URL=https://www.craftybot.online

# Jackpot contract filters.
# DEPRECATED: jackpot is now determined by prob-weighted ev_ratio (see below), not price ratio.
# HUNT_JACKPOT_RATIO_THRESHOLD is no longer read by the code.
# HUNT_JACKPOT_RATIO_THRESHOLD=5.0
# Min profit-probability for jackpot contracts (more lenient than normal HUNT_MIN_PP).
HUNT_JACKPOT_MIN_PP=0.15
# Unified jackpot gate: jackpot_ratio * chance_of_best_output >= this value.
# e.g. 0.5 means the best-skin lottery alone must cover ≥50% of input cost in expectation.
# Contracts meeting this are treated as jackpot (bypass ROI/EV thresholds, only PP checked).
HUNT_JACKPOT_MIN_EV_RATIO=0.5

# CSFloat settings for float optimization
# Disabled until daily rate limit resets (midnight UTC)
CSFLOAT_ENABLED=0
CSFLOAT_RATE_LIMIT_COOLDOWN_DEFAULT=60
CSFLOAT_CACHE_TTL=3600
CSFLOAT_MAX_PAGES=1
CSFLOAT_HTTP_RETRIES=2
CSFLOAT_STATS=1
CSFLOAT_MAX_CONSECUTIVE_429=5
CSFLOAT_SESSION_REQUEST_LIMIT=300
HUNT_REFINE_ENABLE=1
HUNT_REFINE_TOPK=25

DETAILS_WARMUP_ENABLE=1
DETAILS_WARMUP_TOPN=30
OUTCOMES_WARMUP_TOPN=30