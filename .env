# Float optimization and liquidity checks
HUNT_OPTIMIZE_FLOATS=1
HUNT_FN_LIQUIDITY_CHECK=1
HUNT_MIN_IMB=0.8

# Contracts requiring input float below this threshold are skipped when CSFloat
# is unavailable — market cache prices for ultra-clean skins are unreliable.
# Default 0.05 covers the bottom half of FN range where price spikes sharply.
HUNT_LIQUIDITY_FLOAT_THRESHOLD=0.05
HUNT_MAX_TARGETS_PER_RARITY=400
HUNT_EXPLORATION_RATE=0.30
# Debug and logging settings
HUNT_DEBUG=0
HUNT_DEBUG_EVAL=0
HUNT_DEBUG_EVAL_MAX=2000
HUNT_PROFILE=0
SALES_PROFILE=0

